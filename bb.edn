{:paths ["src"]
 :deps {org.babashka/cli {:mvn/version "0.8.61"}}
 :tasks
 {:override-builtin true
  run {:doc "Scan files for deprecated patterns"
       :task (apply (requiring-resolve 'deprecation-detective.core/-main) *command-line-args*)}
  test {:doc "Run tests"
        :task (shell "bb test/core_test.clj")}
  scan {:doc "Scan current directory"
        :task (apply (requiring-resolve 'deprecation-detective.core/-main) ["--dir" "."])}}}
